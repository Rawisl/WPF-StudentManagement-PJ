<Window x:Class="WPF_StudentManagement_Project.Views.ThemHocSinhWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_StudentManagement_Project.Views"
        mc:Ignorable="d"
        Title="ThemHocSinhWnd" Height="450" Width="800">
    <Grid>
        <Label Content="Thêm học sinh vào lớp" HorizontalAlignment="Left" Margin="22,21,0,0" VerticalAlignment="Top" FontSize="24" Height="40"/>
        <Button x:Name="ExitButton" Content="X" HorizontalAlignment="Left" Height="40" Margin="708,10,0,0" VerticalAlignment="Top" Width="82" Background="White" BorderBrush="{x:Null}" UseLayoutRounding="False" Click="ExitButton_Click"/>
        <Button x:Name="SaveButton" Content="Lưu" HorizontalAlignment="Left" Height="50" Margin="671,374,0,0" VerticalAlignment="Top" Width="119"/>
        <ListBox x:Name="ThemHSLB" HorizontalAlignment="Center" Height="308" Margin="0,66,0,0" 
         VerticalAlignment="Top" Width="790" SelectionChanged="ListBox_SelectionChanged"
         BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="15" Width="750">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" VerticalAlignment="Center" IsEnabled="True"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HoTen}" FontWeight="SemiBold" FontSize="16" Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding MaHS}" Foreground="Gray" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding GioiTinh}" HorizontalAlignment="Right" Foreground="#34495E"/>
                                <TextBlock Text="{Binding NgaySinh}" Foreground="Gray" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Window>

    