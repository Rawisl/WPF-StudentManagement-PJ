<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_StudentManagement_Project.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="WPF_StudentManagement_Project.Views.TiepNhanUC"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <materialDesign:Card HorizontalAlignment="Center" Height="380" Margin="0,20,0,0" VerticalAlignment="Top" Width="740" Background="White" UniformCornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="1" HorizontalAlignment="Left" Height="360" Stroke="Black" VerticalAlignment="Center" Width="2" Fill="#FFDDDDDD" Grid.ColumnSpan="2"/>
                <StackPanel x:Name="ThongTinSP" Grid.Column="0" Margin="30,20">
                    <Label x:Name="ThongTinLabel" Content="Thông tin cơ bản" FontSize="25" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Label x:Name="HoTenLabel" Content="Họ Tên:" FontWeight="SemiBold" FontSize="18"/>
                    <TextBox x:Name="HoTenTB" Margin="0,5,0,15" Height="30"/>

                    <Label x:Name="GioiTinhLabel" Content="Giới tính:" FontWeight="SemiBold" FontSize="18"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                        <RadioButton x:Name="NamRB" Content="Nam" IsChecked="True" Margin="0,0,20,0"/>
                        <RadioButton x:Name="NuRB" Content="Nữ"/>
                    </StackPanel>

                    <Label x:Name="DateLabel" Content="Ngày sinh:" FontWeight="SemiBold" FontSize="18"/>
                    <DatePicker x:Name="DateBox" Margin="0,5,0,0" Height="30"/>
                </StackPanel>
                <StackPanel x:Name="LienLacSP" Grid.Column="2" Margin="30,20">
                    <Label x:Name="LienLacLabel" Content="Liên lạc" FontSize="25" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Label x:Name="DiaChiLabel" Content="Địa chỉ:" FontWeight="SemiBold" FontSize="18"/>
                    <TextBox x:Name="DiaChiTB" Margin="0,5,0,15" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <Label x:Name="EmailLabel" Content="Email:" FontWeight="SemiBold" FontSize="18"/>
                    <TextBox x:Name="EmailTB" Margin="0,5,0,0" Height="30"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,410,50,0">
            <Button x:Name="ExitButton" Content="Hủy" Width="80" Margin="0,0,10,0" Background="Gray" BorderBrush="Transparent"/>
            <Button x:Name="SaveButton" Content="Lưu" Width="80" Background="#FF270EDC" Foreground="White" Height="28"/>
        </StackPanel>
    </Grid>
</UserControl>
